{"ast":null,"code":"import{useEffect,useState}from'react';export default function useDebouncedValue(value){let delay=arguments.length>1&&arguments[1]!==undefined?arguments[1]:350;const[debounced,setDebounced]=useState(value);useEffect(()=>{const timeoutId=window.setTimeout(()=>setDebounced(value),delay);return()=>window.clearTimeout(timeoutId);},[value,delay]);return debounced;}","map":{"version":3,"names":["useEffect","useState","useDebouncedValue","value","delay","arguments","length","undefined","debounced","setDebounced","timeoutId","window","setTimeout","clearTimeout"],"sources":["/Users/eshwarchowdaryt/Projecttt/frontend/src/hooks/useDebouncedValue.ts"],"sourcesContent":["import { useEffect, useState } from 'react';\n\nexport default function useDebouncedValue<T>(value: T, delay = 350): T {\n  const [debounced, setDebounced] = useState<T>(value);\n\n  useEffect(() => {\n    const timeoutId = window.setTimeout(() => setDebounced(value), delay);\n    return () => window.clearTimeout(timeoutId);\n  }, [value, delay]);\n\n  return debounced;\n}\n"],"mappings":"AAAA,OAASA,SAAS,CAAEC,QAAQ,KAAQ,OAAO,CAE3C,cAAe,SAAS,CAAAC,iBAAiBA,CAAIC,KAAQ,CAAkB,IAAhB,CAAAC,KAAK,CAAAC,SAAA,CAAAC,MAAA,IAAAD,SAAA,MAAAE,SAAA,CAAAF,SAAA,IAAG,GAAG,CAChE,KAAM,CAACG,SAAS,CAAEC,YAAY,CAAC,CAAGR,QAAQ,CAAIE,KAAK,CAAC,CAEpDH,SAAS,CAAC,IAAM,CACd,KAAM,CAAAU,SAAS,CAAGC,MAAM,CAACC,UAAU,CAAC,IAAMH,YAAY,CAACN,KAAK,CAAC,CAAEC,KAAK,CAAC,CACrE,MAAO,IAAMO,MAAM,CAACE,YAAY,CAACH,SAAS,CAAC,CAC7C,CAAC,CAAE,CAACP,KAAK,CAAEC,KAAK,CAAC,CAAC,CAElB,MAAO,CAAAI,SAAS,CAClB","ignoreList":[]},"metadata":{},"sourceType":"module","externalDependencies":[]}