{"ast":null,"code":"import{useEffect,useState}from'react';export default function useDebouncedValue(value){let delay=arguments.length>1&&arguments[1]!==undefined?arguments[1]:350;const[debounced,setDebounced]=useState(value);useEffect(()=>{const timeoutId=setTimeout(()=>setDebounced(value),delay);return()=>clearTimeout(timeoutId);},[value,delay]);return debounced;}","map":{"version":3,"names":["useEffect","useState","useDebouncedValue","value","delay","arguments","length","undefined","debounced","setDebounced","timeoutId","setTimeout","clearTimeout"],"sources":["/Users/eshwarchowdaryt/Projecttt/frontend/src/hooks/useDebouncedValue.js"],"sourcesContent":["import { useEffect, useState } from 'react';\n\nexport default function useDebouncedValue(value, delay = 350) {\n  const [debounced, setDebounced] = useState(value);\n\n  useEffect(() => {\n    const timeoutId = setTimeout(() => setDebounced(value), delay);\n    return () => clearTimeout(timeoutId);\n  }, [value, delay]);\n\n  return debounced;\n}\n"],"mappings":"AAAA,OAASA,SAAS,CAAEC,QAAQ,KAAQ,OAAO,CAE3C,cAAe,SAAS,CAAAC,iBAAiBA,CAACC,KAAK,CAAe,IAAb,CAAAC,KAAK,CAAAC,SAAA,CAAAC,MAAA,IAAAD,SAAA,MAAAE,SAAA,CAAAF,SAAA,IAAG,GAAG,CAC1D,KAAM,CAACG,SAAS,CAAEC,YAAY,CAAC,CAAGR,QAAQ,CAACE,KAAK,CAAC,CAEjDH,SAAS,CAAC,IAAM,CACd,KAAM,CAAAU,SAAS,CAAGC,UAAU,CAAC,IAAMF,YAAY,CAACN,KAAK,CAAC,CAAEC,KAAK,CAAC,CAC9D,MAAO,IAAMQ,YAAY,CAACF,SAAS,CAAC,CACtC,CAAC,CAAE,CAACP,KAAK,CAAEC,KAAK,CAAC,CAAC,CAElB,MAAO,CAAAI,SAAS,CAClB","ignoreList":[]},"metadata":{},"sourceType":"module","externalDependencies":[]}